# Landing env (copy → landing/.env.local, then: bash scripts/website_publish.sh)
# Bu dosya commit edilmez (.gitignore).

# Cloudflare Web Analytics — Dashboard → Web Analytics → site token
# veya: LG_CF_API_TOKEN=... bash scripts/website_search_setup.sh
NEXT_PUBLIC_CF_BEACON=

# Google Search Console — HTML meta tag yöntemi (content kısmı, tırnaksız)
# Search Console → Mülk ekle → HTML etiketi → content="..." içindeki değer
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
