# /etc/log-guardian/threat-feed.env — chmod 600, commit ETME
# DUZENLE:  sudo nano /etc/log-guardian/threat-feed.env
# CALISTIRMA: bash bu dosyayi — env dosyasi, script degil
#
# Laptop: bos birakilabilir — Firehol (key'siz) yeterli
# Internet: API sync icin cikis agi gerekir (Wi-Fi OK)
# Kurulum: sudo bash scripts/install_threat_feed_live.sh  (~30 sn-2 dk, key doluysa)
#
# AbuseIPDB (ucretsiz): https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# AlienVault OTX (ucretsiz): https://otx.alienvault.com → Settings → API Key
OTX_API_KEY=

# Opsiyonel alias (ABUSEIPDB_API_KEY yerine):
# THREAT_FEED_API_KEY=
