# rules.conf webhook blogu — prod URL'leri doldurun, WEBHOOK_ENABLED=1 yapin
WEBHOOK_ENABLED=0
WEBHOOK_MIN_LEVEL=2
WEBHOOK_COOLDOWN_SEC=60

# Prod token: /etc/log-guardian/webhook.env (LOGANALYZER_TELEGRAM_*)
# Laptop: .env.webhook.local — bash scripts/webhook_apply_local.sh
# Kurulum: sudo bash scripts/webhook_install_prod.sh

# Dev (URL gerekmez):
#   bash scripts/webhook_test_cli.sh alert
