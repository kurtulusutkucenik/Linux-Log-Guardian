# Webhook yerel sır — GitHub'a ASLA commit etmeyin
# Kopyala: cp deploy/webhook.local.env.example .env.webhook.local
# Doldur, sonra: bash scripts/webhook_apply_local.sh

WEBHOOK_ENABLED=1
WEBHOOK_MIN_LEVEL=2
WEBHOOK_COOLDOWN_SEC=60
# WEBHOOK_TELEGRAM_BOT=1   # /status /bans + inline Gordum butonu
# ALERT_COOLDOWN_SEC=10
WEBHOOK_DRY_RUN=0

# En az bir kanal doldurun (bos birakilanlar atlanir)

# --- Telegram (TR icin onerilen) ---
# @BotFather -> bot token; kanal ID (@userinfobot veya getUpdates)
# LOGANALYZER_TELEGRAM_TOKEN=123456789:ABCdef...
# LOGANALYZER_TELEGRAM_CHAT_ID=-1001234567890
# Kanal + DM birlikte: -1001234567890,123456789
# LOGANALYZER_TELEGRAM_CHAT_IDS=-100...,123456789

# --- P2: Seviye bazli yonlendirme (opsiyonel) ---
# WEBHOOK_TELEGRAM_ROUTE=1
# LOGANALYZER_TELEGRAM_CHAT_CRIT=-1001234567890   # kanal — CRIT alarm, ban, tuzak
# LOGANALYZER_TELEGRAM_CHAT_WARN=123456789       # DM — WARN/INFO
# WEBHOOK_TELEGRAM_BATCH_SEC=10                   # WARN/INFO ozet (0=kapali)
# CRIT/WARN bos ise LOGANALYZER_TELEGRAM_CHAT_ID fallback kullanilir

# --- Discord (TR'de erisim engelli — VPN gerekir veya baska kanal kullanin) ---
# LOGANALYZER_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/SUNUCU_ID/TOKEN

# --- Slack ---
# LOGANALYZER_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T/B/SECRET

# --- Generic JSON POST ---
# LOGANALYZER_GENERIC_WEBHOOK_URL=https://example.com/hooks/log-guardian
