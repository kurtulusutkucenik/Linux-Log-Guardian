# Grafana alert Telegram — LG Ops grubundan AYRI (#30)
# Kopyala: cp deploy/grafana.telegram.env.example .env.grafana.telegram.local
#
# Onerilen A: operator DM (LOGANALYZER_TELEGRAM_CHAT_WARN)
# Onerilen B: Ops supergroup + forum topic (LOGANALYZER_TELEGRAM_CHAT_ID + WEBHOOK_TELEGRAM_TOPIC_WARN=17)
#
# GRAFANA_TELEGRAM_BOT_TOKEN=123456:ABC...   # ayri bot veya LG botu
# GRAFANA_TELEGRAM_CHAT_ID=123456789         # kisisel DM
#
# Hizli (token tekrar yazma):
#   bash scripts/grafana_telegram_contact.sh --from-webhook-warn --test
