# Webhook ortam degiskenleri — /etc/log-guardian/env dosyasina veya systemd drop-in'e ekleyin
# Kopyala: sudo cp deploy/webhook.env.example /etc/log-guardian/webhook.env
# systemd: EnvironmentFile=/etc/log-guardian/webhook.env (log-guardian.service)

WEBHOOK_ENABLED=1
WEBHOOK_MIN_LEVEL=2
WEBHOOK_COOLDOWN_SEC=60
# WEBHOOK_DRY_RUN=0

# LOGANALYZER_TELEGRAM_TOKEN=
# LOGANALYZER_TELEGRAM_CHAT_ID=
# WEBHOOK_TELEGRAM_ROUTE=1
# LOGANALYZER_TELEGRAM_CHAT_CRIT=-100...
# LOGANALYZER_TELEGRAM_CHAT_WARN=123456789
# WEBHOOK_TELEGRAM_TOPIC_WAF=12
# WEBHOOK_TELEGRAM_TOPIC_BAN=14
# WEBHOOK_TELEGRAM_TOPIC_TRAP=16
# WEBHOOK_TELEGRAM_TOPIC_WARN=18
# WEBHOOK_TELEGRAM_MIRROR_WARN=1
# WEBHOOK_DASHBOARD_BASE_URL=http://127.0.0.1:3000
# WEBHOOK_TELEGRAM_RICH_CARD=1
# WEBHOOK_TELEGRAM_DISABLE_PREVIEW=1
# WEBHOOK_TELEGRAM_REPLY_CHAIN=1
# WEBHOOK_TELEGRAM_REPLY_CHAIN_SEC=86400
# WEBHOOK_TELEGRAM_GEOIP=1
# WEBHOOK_TELEGRAM_PIN_CRIT=1
# WEBHOOK_TELEGRAM_CARD_PHOTO_URL=https://example.com/log-guardian-card.png
# WEBHOOK_TELEGRAM_WEBHOOK_URL=https://your.domain/telegram/webhook
# WEBHOOK_TELEGRAM_WEBHOOK_SECRET=uzun-rastgele-dize
# WEBHOOK_DAILY_SUMMARY=08:00
# WEBHOOK_WEEKLY_SUMMARY=Sun:20:00
# LOGANALYZER_GENERIC_WEBHOOK_URL=
