# Cloudflare publish cache purge (repoya commit ETME)
#   mkdir -p ~/.config/log-guardian
#   cp scripts/cloudflare.env.example ~/.config/log-guardian/cloudflare.env
#   chmod 600 ~/.config/log-guardian/cloudflare.env
#
# Token: Cloudflare Dashboard → My Profile → API Tokens
#   Zone.Cache Purge + Zone.Zone Read
LG_CF_API_TOKEN=
# Opsiyonel — bos birakilirsa zone adindan bulunur
LG_CF_ZONE_ID=
# Token yokken publish sonrasi live gate (varsayilan: 3 deneme, 15s aralik, 20s ilk bekleme)
# LG_LIVE_GATE_RETRIES=3
# LG_LIVE_GATE_RETRY_SEC=15
# LG_LIVE_GATE_WARMUP_SEC=20
